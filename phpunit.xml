<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         verbose="true"
         stopOnFailure="false">
    
    <testsuites>
        <testsuite name="Models">
            <directory>tests/Models</directory>
        </testsuite>
        <testsuite name="Repositories">
            <directory>tests/Repositories</directory>
        </testsuite>
        <testsuite name="Services">
            <directory>tests/Services</directory>
        </testsuite>
        <testsuite name="Database">
            <directory>tests/Database</directory>
        </testsuite>
        <testsuite name="Procedural">
            <directory>tests/Procedural</directory>
        </testsuite>
    </testsuites>
    
    <source>
        <include>
            <directory suffix=".php">oop</directory>
            <directory suffix=".php">procedural</directory>
            <directory suffix=".php">database</directory>
        </include>
    </source>
    
    <php>
        <ini name="display_errors" value="1"/>
        <ini name="error_reporting" value="-1"/>
    </php>
</phpunit>
